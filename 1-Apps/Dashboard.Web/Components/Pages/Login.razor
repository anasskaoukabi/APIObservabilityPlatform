@page "/login"
@rendermode InteractiveServer
@using Dashboard.Web.Models
@using Dashboard.Web.Services
@inject AuthService Auth
@inject NavigationManager Navigation

<PageTitle>Authentification — API Observability Platform</PageTitle>

<div class="login-wrapper">
    <div class="glow-orb orb-1"></div>
    <div class="glow-orb orb-2"></div>

    <div class="login-container">
        <div class="login-header">
            <span class="login-logo-icon">📡</span>
            <h1 class="login-title">API Observability</h1>
            <p class="login-subtitle">Supervision & Monitoring de Services</p>
        </div>

        <div class="auth-card">
            <!-- Tabs -->
            <div class="auth-tabs">
                <button class="auth-tab @(_isLoginTab ? "active" : "")" @onclick="() => SetTab(true)">
                    Connexion
                </button>
                <button class="auth-tab @(!_isLoginTab ? "active" : "")" @onclick="() => SetTab(false)">
                    Inscription
                </button>
            </div>

            <!-- Forms -->
            <div class="auth-form-body">
                @if (_isLoginTab)
                {
                    <p class="auth-tab-desc">Connectez-vous pour accéder au tableau de bord.</p>

                    <div class="form-group">
                        <label class="form-label">Nom d'utilisateur</label>
                        <div class="input-wrapper">
                            <span class="input-icon">👤</span>
                            <input class="form-input" @bind="_loginUsername" @bind:event="oninput" @onkeydown="HandleKeyDown" placeholder="Ex: admin" />
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Mot de passe</label>
                        <div class="input-wrapper">
                            <span class="input-icon">🔑</span>
                            <input class="form-input" type="password" @bind="_loginPassword" @bind:event="oninput" @onkeydown="HandleKeyDown" placeholder="Ex: admin123" />
                        </div>
                    </div>

                    @if (_errorMessage is not null)
                    {
                        <div class="auth-error">⚠ @_errorMessage</div>
                    }

                    <button class="btn-auth" @onclick="SubmitLogin" disabled="@_loading">
                        @if (_loading)
                        {
                            <span class="spinner"></span> <span>Connexion...</span>
                        }
                        else
                        {
                            <span>Se connecter 🚀</span>
                        }
                    </button>

                    <div class="default-creds-hint">
                        💡 Admin par défaut : <strong>admin</strong> / <strong>admin123</strong>
                    </div>
                }
                else
                {
                    <p class="auth-tab-desc">Créez un compte pour monitorer vos propres services.</p>

                    <div class="form-group">
                        <label class="form-label">Nom d'utilisateur</label>
                        <div class="input-wrapper">
                            <span class="input-icon">👤</span>
                            <input class="form-input" @bind="_registerUsername" @bind:event="oninput" placeholder="Choisissez un pseudo" />
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Adresse Email</label>
                        <div class="input-wrapper">
                            <span class="input-icon">✉</span>
                            <input class="form-input" type="email" @bind="_registerEmail" @bind:event="oninput" placeholder="admin@exemple.com" />
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Mot de passe</label>
                        <div class="input-wrapper">
                            <span class="input-icon">🔑</span>
                            <input class="form-input" type="password" @bind="_registerPassword" @bind:event="oninput" placeholder="Entrez un mot de passe sécurisé" />
                        </div>
                    </div>

                    @if (_errorMessage is not null)
                    {
                        <div class="auth-error">⚠ @_errorMessage</div>
                    }

                    <button class="btn-auth btn-register" @onclick="SubmitRegister" disabled="@_loading">
                        @if (_loading)
                        {
                            <span class="spinner"></span> <span>Création du compte...</span>
                        }
                        else
                        {
                            <span>Créer mon compte et accéder ✓</span>
                        }
                    </button>
                }
            </div>
        </div>
    </div>
</div>

<style>
    /* CSS Scoped haut de gamme pour l'écran de Login/Signin */
    .login-wrapper {
        position: relative;
        min-height: 100vh;
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        background: radial-gradient(circle at center, #1b1b2d 0%, #0b0b12 100%);
        overflow: hidden;
        font-family: 'Inter', system-ui, sans-serif;
    }

    .glow-orb {
        position: absolute;
        width: 400px;
        height: 400px;
        border-radius: 50%;
        filter: blur(120px);
        opacity: 0.15;
        z-index: 1;
        pointer-events: none;
    }

    .orb-1 {
        background: var(--accent, #00e887);
        top: -100px;
        left: -100px;
        animation: floatOrb 20s infinite alternate;
    }

    .orb-2 {
        background: #9d4edd;
        bottom: -100px;
        right: -100px;
        animation: floatOrb 25s infinite alternate-reverse;
    }

    @@keyframes floatOrb {
        0% { transform: translate(0, 0) scale(1); }
        100% { transform: translate(50px, 50px) scale(1.2); }
    }

    .login-container {
        position: relative;
        z-index: 2;
        width: 100%;
        max-width: 440px;
        padding: 20px;
        animation: fadeIn 0.6s ease-out;
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(15px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .login-header {
        text-align: center;
        margin-bottom: 24px;
    }

    .login-logo-icon {
        display: inline-block;
        font-size: 40px;
        margin-bottom: 12px;
        filter: drop-shadow(0 0 10px rgba(0, 232, 135, 0.4));
        animation: pulseLogo 3s infinite;
    }

    @@keyframes pulseLogo {
        0%, 100% { transform: scale(1); }
        50% { transform: scale(1.05); }
    }

    .login-title {
        font-size: 26px;
        font-weight: 800;
        color: #ffffff;
        letter-spacing: -0.5px;
        margin: 0 0 4px 0;
    }

    .login-subtitle {
        font-size: 13px;
        color: #8f92a1;
        margin: 0;
    }

    .auth-card {
        background: rgba(22, 22, 37, 0.75);
        backdrop-filter: blur(16px);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 16px;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
        overflow: hidden;
    }

    .auth-tabs {
        display: flex;
        background: rgba(255, 255, 255, 0.02);
        border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    }

    .auth-tab {
        flex: 1;
        background: none;
        border: none;
        padding: 16px;
        font-size: 14px;
        font-weight: 600;
        color: #8f92a1;
        cursor: pointer;
        transition: all 0.3s;
        text-align: center;
    }

    .auth-tab:hover {
        color: #ffffff;
        background: rgba(255, 255, 255, 0.01);
    }

    .auth-tab.active {
        color: var(--accent, #00e887);
        border-bottom: 2px solid var(--accent, #00e887);
        background: rgba(255, 255, 255, 0.03);
    }

    .auth-form-body {
        padding: 28px 24px;
    }

    .auth-tab-desc {
        font-size: 13px;
        color: #8f92a1;
        margin-top: 0;
        margin-bottom: 20px;
    }

    .form-group {
        margin-bottom: 18px;
    }

    .form-label {
        display: block;
        font-size: 12px;
        font-weight: 600;
        color: #b3b5c6;
        margin-bottom: 8px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .input-wrapper {
        position: relative;
        display: flex;
        align-items: center;
    }

    .input-icon {
        position: absolute;
        left: 14px;
        font-size: 14px;
        color: #8f92a1;
        pointer-events: none;
    }

    .form-input {
        width: 100%;
        padding: 12px 14px 12px 40px;
        background: rgba(10, 10, 18, 0.6);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 8px;
        color: #ffffff;
        font-size: 14px;
        outline: none;
        transition: all 0.3s;
    }

    .form-input:focus {
        border-color: var(--accent, #00e887);
        box-shadow: 0 0 0 3px rgba(0, 232, 135, 0.15);
        background: rgba(10, 10, 18, 0.8);
    }

    .auth-error {
        background: rgba(235, 87, 87, 0.1);
        border: 1px solid rgba(235, 87, 87, 0.2);
        color: #eb5757;
        font-size: 13px;
        padding: 10px 12px;
        border-radius: 8px;
        margin-bottom: 18px;
        animation: shake 0.3s;
    }

    @@keyframes shake {
        0%, 100% { transform: translateX(0); }
        25% { transform: translateX(-4px); }
        75% { transform: translateX(4px); }
    }

    .btn-auth {
        width: 100%;
        padding: 12px;
        background: linear-gradient(135deg, var(--accent, #00e887) 0%, #00c773 100%);
        border: none;
        border-radius: 8px;
        color: #0b0b12;
        font-size: 14px;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.3s;
        box-shadow: 0 4px 15px rgba(0, 232, 135, 0.2);
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }

    .btn-auth:hover:not(:disabled) {
        transform: translateY(-1px);
        box-shadow: 0 6px 20px rgba(0, 232, 135, 0.35);
        filter: brightness(1.05);
    }

    .btn-auth:disabled {
        opacity: 0.6;
        cursor: not-allowed;
    }

    .btn-register {
        background: linear-gradient(135deg, #9d4edd 0%, #7b2cbf 100%);
        color: #ffffff;
        box-shadow: 0 4px 15px rgba(157, 78, 221, 0.2);
    }

    .btn-register:hover:not(:disabled) {
        box-shadow: 0 6px 20px rgba(157, 78, 221, 0.35);
    }

    .default-creds-hint {
        font-size: 11px;
        color: #6a6e85;
        text-align: center;
        margin-top: 18px;
        padding-top: 12px;
        border-top: 1px solid rgba(255, 255, 255, 0.04);
    }

    .default-creds-hint strong {
        color: #a8abbf;
    }

    .spinner {
        width: 16px;
        height: 16px;
        border: 2px solid rgba(255, 255, 255, 0.3);
        border-top-color: #ffffff;
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
    }

    @@keyframes spin {
        to { transform: rotate(360deg); }
    }
</style>

@code {
    private bool _isLoginTab = true;
    private bool _loading = false;
    private string? _errorMessage;

    // Login fields
    private string _loginUsername = "";
    private string _loginPassword = "";

    // Register fields
    private string _registerUsername = "";
    private string _registerEmail = "";
    private string _registerPassword = "";

    protected override void OnInitialized()
    {
        // Si l'utilisateur est déjà connecté, on redirige vers l'accueil
        if (Auth.IsAuthenticated)
        {
            Navigation.NavigateTo("/");
        }
    }

    private void SetTab(bool isLogin)
    {
        _isLoginTab = isLogin;
        _errorMessage = null;
    }

    private async Task SubmitLogin()
    {
        _errorMessage = null;
        if (string.IsNullOrWhiteSpace(_loginUsername) || string.IsNullOrWhiteSpace(_loginPassword))
        {
            _errorMessage = "Veuillez remplir tous les champs.";
            return;
        }

        _loading = true;
        StateHasChanged();

        // Simulation d'une latence réseau agréable
        await Task.Delay(800);

        bool success = Auth.Login(_loginUsername, _loginPassword);
        _loading = false;

        if (success)
        {
            Navigation.NavigateTo("/");
        }
        else
        {
            _errorMessage = "Nom d'utilisateur ou mot de passe incorrect.";
        }
    }

    private async Task SubmitRegister()
    {
        _errorMessage = null;
        if (string.IsNullOrWhiteSpace(_registerUsername) || string.IsNullOrWhiteSpace(_registerEmail) || string.IsNullOrWhiteSpace(_registerPassword))
        {
            _errorMessage = "Veuillez remplir tous les champs.";
            return;
        }

        if (!_registerEmail.Contains("@") || !_registerEmail.Contains("."))
        {
            _errorMessage = "Veuillez entrer une adresse email valide.";
            return;
        }

        if (_registerPassword.Length < 6)
        {
            _errorMessage = "Le mot de passe doit faire au moins 6 caractères.";
            return;
        }

        _loading = true;
        StateHasChanged();

        await Task.Delay(1000);

        bool success = Auth.Register(_registerUsername, _registerEmail, _registerPassword);
        _loading = false;

        if (success)
        {
            Navigation.NavigateTo("/");
        }
        else
        {
            _errorMessage = "Ce nom d'utilisateur est déjà utilisé.";
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SubmitLogin();
        }
    }
}
