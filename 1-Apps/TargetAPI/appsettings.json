{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  // ─────────────────────────────────────────────────────────────────────────
  //  Configuration du Middleware de Simulation de Pannes
