<?xml version="1.0" encoding="utf-8"?>
<!--
  NuGet.Config au niveau de la solution.
  Active nuget.org comme source principale et désactive le PackageSourceMapping
  restrictif hérité de la machine, pour que la restauration des packages fonctionne.
-->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
  <!-- Désactive le filtrage par source pour cette solution -->
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
